language core;

extend with
  #unit-type,
  #references,
  #arithmetic-operators,
  #sequencing,
  #natural-literals,
  #structural-subtyping;
extend with #records;
extend with #bottom-type;
extend with #panic;
extend with #variants;

fn test(n : Nat) -> {a : <| c : Nat |>, b : Bool} {
  return { a = <| c = 0 |>, b = false }
}

fn main(n : Nat) -> {a : <| c : Nat, d : Bool |>} {
  return test(n)
}
